<div class="card">
  <h2>Runs</h2>
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Source</th>
        <th>Status</th>
        <th>Prompt</th>
        <th>Started</th>
      </tr>
    </thead>
    <tbody>
      <% @runs.each do |run| %>
        <tr>
          <td><%= link_to "##{run.id}", run_path(run) %></td>
          <td><%= run.source_type %></td>
          <td><span class="badge <%= status_badge_class(run.status) %>"><%= run.status %></span></td>
          <td><%= run.prompt.to_s.truncate(60) %></td>
          <td><%= time_ago_tag(run.created_at) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
