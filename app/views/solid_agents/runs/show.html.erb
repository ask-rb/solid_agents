<div class="card">
  <h2>Run #<%= @run.id %></h2>
  <p>
    Status: <span class="badge <%= status_badge_class(@run.status) %>"><%= @run.status %></span> |
    Source: <%= @run.source_type %> |
    Runtime: <%= @run.runtime %>
  </p>

  <% if @run.prompt.present? %>
    <h3>Prompt</h3>
    <pre><%= @run.prompt %></pre>
  <% end %>

  <% if @run.output.present? %>
    <h3>Response</h3>
    <pre><%= @run.output %></pre>
  <% end %>
</div>

<div class="grid">
  <div class="card">
    <h3>Events</h3>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Type</th>
          <th>Actor</th>
          <th>Message</th>
        </tr>
      </thead>
      <tbody>
        <% @events.each do |event| %>
          <tr>
            <td><%= event.sequence %></td>
            <td><%= event.event_type %></td>
            <td><%= event.actor %></td>
            <td><%= event.message %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h3>Artifacts</h3>
    <% @artifacts.each do |artifact| %>
      <h4><%= artifact.label || artifact.kind %></h4>
      <% if artifact.content_text.present? %>
        <pre><%= artifact.content_text %></pre>
      <% end %>
    <% end %>
  </div>
</div>

<%= button_to "Retry", retry_run_path(@run), method: :post, class: "btn" %>
