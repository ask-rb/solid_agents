<div class="card">
  <h2>Edit Schedule: <%= @schedule.key %></h2>
  <%= form_with model: @schedule, url: schedule_path(@schedule), method: :patch do |f| %>
    <p><%= f.label :key %><br><%= f.text_field :key %></p>
    <p><%= f.label :cron, "Cron expression" %><br><%= f.text_field :cron %></p>
    <p><%= f.label :prompt %><br><%= f.text_area :prompt, rows: 5 %></p>
    <p><%= f.label :model %><br><%= f.text_field :model %></p>
    <p><%= f.label :enabled %><br><%= f.check_box :enabled %></p>
    <%= f.submit "Save", class: "btn primary" %>
  <% end %>
</div>
