<style>
  :root {
    --bg: #f4f7fb;
    --surface: #ffffff;
    --ink: #17202a;
    --muted: #5e6b78;
    --line: #dbe4ee;
    --accent: #0f766e;
    --good: #166534;
    --bad: #b91c1c;
    --run: #7c3aed;
    --user-bg: #ecfeff;
    --assistant-bg: #f8fafc;
    --sidebar-width: 280px;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--bg);
    color: var(--ink);
    line-height: 1.5;
  }

  /* Layout */
  .chat-layout { display: flex; height: calc(100vh - 52px); gap: 0; margin: 0; width: 100%; max-width: 100%; }
  .chat-layout > .wrap { max-width: 100%; width: 100%; display: flex; }

  .sidebar {
    width: var(--sidebar-width);
    flex-shrink: 0;
    border-right: 1px solid var(--line);
    background: var(--surface);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }

  .sidebar-header { border-radius: 0; margin: 0; border: none; border-bottom: 1px solid var(--line); }
  .sidebar-header h2 { margin: 0 0 0.5rem 0; font-size: 0.95rem; }

  .session-list { flex: 1; overflow-y: auto; }

  .session-item {
    display: block;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--line);
    text-decoration: none;
    color: var(--ink);
  }

  .session-item:hover, .session-item.active { background: var(--bg); }
  .session-title { display: block; font-size: 0.875rem; font-weight: 500; }
  .session-meta { display: block; font-size: 0.75rem; color: var(--muted); margin-top: 0.15rem; }

  .chat-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: var(--surface);
  }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .message {
    max-width: 75%;
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    line-height: 1.5;
  }

  .message.user {
    align-self: flex-end;
    background: var(--accent);
    color: #fff;
    border-bottom-right-radius: 0.25rem;
  }

  .message.assistant {
    align-self: flex-start;
    background: var(--assistant-bg);
    border: 1px solid var(--line);
    border-bottom-left-radius: 0.25rem;
  }

  .message.error {
    align-self: flex-start;
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: var(--bad);
  }

  .message-content p { margin: 0; }
  .message-content p + p { margin-top: 0.5rem; }

  .chat-input {
    display: flex;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--line);
    background: var(--surface);
  }

  .chat-input .input { flex: 1; }

  .empty-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    text-align: center;
    padding: 2rem;
  }

  .empty-state h2 { color: var(--ink); margin-bottom: 0.5rem; }

  /* Top bar */
  .wrap { width: min(1100px, 94vw); margin: 0 auto; }

  .topbar {
    background: var(--surface);
    border-bottom: 1px solid var(--line);
    height: 52px;
  }

  .topbar .wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0;
    height: 100%;
    max-width: 100%;
    width: 100%;
    padding: 0 1rem;
  }

  .topbar h1 { font-size: 1.1rem; margin: 0; }
  .topbar h1 a { color: var(--ink); text-decoration: none; }

  .topbar nav { display: flex; gap: 0.25rem; }

  .topbar a {
    color: var(--ink);
    text-decoration: none;
    padding: 0.35rem 0.65rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
  }

  .topbar a:hover { background: var(--bg); }

  /* Cards */
  .card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 0.9rem;
    padding: 1rem;
    margin-bottom: 1rem;
  }

  /* Tables */
  table { width: 100%; border-collapse: collapse; }

  th, td {
    text-align: left;
    padding: 0.65rem 0.5rem;
    border-bottom: 1px solid var(--line);
    font-size: 0.93rem;
  }

  th { color: var(--muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; }

  /* Badges */
  .badge {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    border-radius: 0.55rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .badge.ok { background: #dcfce7; color: var(--good); }
  .badge.err { background: #fee2e2; color: var(--bad); }
  .badge.run { background: #ede9fe; color: var(--run); }
  .badge.muted { background: #eef2f7; color: var(--muted); }

  /* Grid */
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  /* Flash */
  .flash {
    padding: 0.6rem 0.8rem;
    border-radius: 0.65rem;
    border: 1px solid var(--line);
    margin: 1rem 0;
  }

  .notice { background: #ecfeff; }
  .alert { background: #fff7ed; }

  /* Forms */
  .input {
    border: 1px solid var(--line);
    border-radius: 0.55rem;
    padding: 0.5rem 0.7rem;
    font-size: 0.9rem;
    font-family: inherit;
    width: 100%;
  }

  .input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px rgba(15,118,110,0.1); }

  textarea.input { resize: vertical; min-height: 80px; }

  .btn {
    display: inline-block;
    border: 1px solid var(--line);
    background: #fff;
    color: var(--ink);
    border-radius: 0.55rem;
    padding: 0.45rem 0.7rem;
    text-decoration: none;
    cursor: pointer;
    font-size: 0.875rem;
    font-family: inherit;
    white-space: nowrap;
  }

  .btn:hover { background: var(--bg); }
  .btn.primary { background: var(--accent); border-color: var(--accent); color: #fff; }
  .btn.primary:hover { background: #0d6b64; }

  .link-button { background: none; border: none; color: var(--accent); cursor: pointer; font-size: inherit; padding: 0; text-decoration: underline; font-family: inherit; }

  .new-session-form { display: flex; gap: 0.25rem; margin-top: 0.5rem; }
  .new-session-form .input { flex: 1; font-size: 0.8rem; padding: 0.35rem 0.5rem; }

  pre {
    background: #0b1220;
    color: #d1e0ff;
    border-radius: 0.8rem;
    padding: 0.85rem;
    overflow: auto;
    font-size: 0.82rem;
    line-height: 1.4;
  }

  label { font-size: 0.875rem; font-weight: 500; color: var(--muted); }

  @media (max-width: 800px) {
    .sidebar { display: none; }
    .message { max-width: 90%; }
    .grid { grid-template-columns: 1fr; }
  }
</style>
